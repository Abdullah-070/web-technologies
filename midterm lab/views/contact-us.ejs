<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Us - Auto Care</title>
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/contact-us.css">
</head>
<body>
    <!-- TOP HEADER -->
    <header class="top-header">
        <div class="container">
            <div class="header-content">
                <div class="logo-section">
                    <img src="/logo.png" alt="Auto Care" class="logo">
                    <h2>Auto Care</h2>
                </div>
                <div class="header-buttons">
                    <button class="btn btn-outline-primary">Become a Partner</button>
                    <button class="btn btn-outline-dark">Login</button>
                    <button class="btn btn-danger">Sign Up</button>
                </div>
            </div>
        </div>

    <!-- NAVIGATION BAR -->
    <nav class="navbar">
        <div class="container">
            <button class="hamburger-btn" id="hamburgerBtn" aria-label="Toggle menu">
                <span class="hamburger-line"></span>
                <span class="hamburger-line"></span>
                <span class="hamburger-line"></span>
            </button>
            
            <div class="navbar-content" id="navbarContent">
                <ul class="navbar-nav">
                    <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="/#about">About</a></li>
                    <li class="nav-item"><a class="nav-link" href="/contact-us">Contact</a></li>
                    <li class="nav-item dropdown-menu-container">
                        <a class="nav-link" href="/#products">Products</a>
                        <div class="dropdown-menu-custom">
                            <a href="#products-category-1">Engine Parts</a>
                            <a href="#products-category-2">Brake Systems</a>
                            <a href="#products-category-3">Lighting</a>
                            <a href="#products-category-4">Batteries</a>
                            <a href="#products-category-5">Filters</a>
                        </div>
                    </li>
                </ul>
                <div class="search-section">
                    <input type="text" class="search-box" placeholder="Search with SKU or Keyword...">
                </div>
            </div>
        </div>
    </nav>
    </header>

    <!-- CONTACT SECTION -->
    <section class="contact-section">
        <div class="container">
            <h1>Contact Us</h1>
            <p>Have questions? We'd love to hear from you. Get in touch with our team.</p>
            
            <div class="contact-info-grid">
                <div class="contact-info-item">
                    <h3>📞 Phone</h3>
                    <p>1-800-AUTO-CARE</p>
                </div>
                <div class="contact-info-item">
                    <h3>📧 Email</h3>
                    <p>support@autocare.com</p>
                </div>
                <div class="contact-info-item">
                    <h3>📍 Address</h3>
                    <p>123 Auto Parts Ave, Service City, SC 12345</p>
                </div>
            </div>

            <!-- Contact Form -->
            <div class="contact-form-container">
                <h3>Send us a Message</h3>
                <form>
                    <div class="form-group">
                        <input type="text" placeholder="Your Name">
                    </div>
                    <div class="form-group">
                        <input type="email" placeholder="Your Email">
                    </div>
                    <div class="form-group">
                        <input type="text" placeholder="Subject">
                    </div>
                    <div class="form-group">
                        <textarea placeholder="Your Message" rows="6"></textarea>
                    </div>
                    <button type="submit" class="contact-form-btn">Send Message</button>
                </form>
            </div>
        </div>
    </section>

    <!-- FOOTER -->
    <footer class="footer-contact">
        <div class="container">
            <p>&copy; 2026 AUTO CARE CO. ALL RIGHTS RESERVED.</p>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="/js/script.js"></script>
</body>
</html>
