<div class="admin-card">
  <div class="extracted-style-7">
    <h3 class="extracted-style-8">Product Categories</h3>
    <a href="/admin/categories/new" class="btn btn-primary">Add New Category</a>
  </div>

  <table class="admin-table">
    <thead>
      <tr>
        <th>
          <a href="/admin/categories?sort=name&order=<%= sortField === 'name' && sortOrder === 'asc' ? 'desc' : 'asc' %>" class="extracted-style-9">
            Name <%= sortField === 'name' ? (sortOrder === 'asc' ? '↑' : '↓') : '' %>
          </a>
        </th>
        <th>Slug</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (categories && categories.length > 0) { %>
        <% categories.forEach(category => { %>
          <tr>
            <td><strong><%= category.name %></strong></td>
            <td><code><%= category.slug %></code></td>
            <td>
              <div class="extracted-style-10">
                <a href="/admin/categories/edit/<%= category._id %>" class="btn btn-sm btn-secondary" title="Edit">
                  <i class="fas fa-edit"></i>
                </a>
                <form action="/admin/categories/delete/<%= category._id %>" method="POST" onsubmit="return confirm('Are you sure?')">
                  <button type="submit" class="btn btn-sm extracted-style-11" title="Delete">
                    <i class="fas fa-trash"></i>
                  </button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      <% } else { %>
        <tr>
          <td colspan="3" class="extracted-style-12">No categories found.</td>
        </tr>
      <% } %>
    </tbody>
  </table>

  <% if (totalPages > 1) { %>
    <div class="extracted-style-13">
      <% if (currentPage > 1) { %>
        <a href="/admin/categories?page=<%= currentPage - 1 %>&sort=<%= sortField %>&order=<%= sortOrder %>" class="btn btn-sm btn-secondary">Prev</a>
      <% } %>
      
      <% for(let i=1; i<=totalPages; i++) { %>
        <a href="/admin/categories?page=<%= i %>&sort=<%= sortField %>&order=<%= sortOrder %>" 
           class="btn btn-sm <%= i === currentPage ? 'btn-primary' : 'btn-secondary' %>">
          <%= i %>
        </a>
      <% } %>

      <% if (currentPage < totalPages) { %>
        <a href="/admin/categories?page=<%= currentPage + 1 %>&sort=<%= sortField %>&order=<%= sortOrder %>" class="btn btn-sm btn-secondary">Next</a>
      <% } %>
    </div>
  <% } %>
</div>
