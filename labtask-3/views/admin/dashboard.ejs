<div class="extracted-style-14">
  <!-- Products Stat -->
  <div class="admin-card extracted-style-15">
    <div class="extracted-style-16"><i class="fas fa-box"></i></div>
    <h3 class="extracted-style-17">Total Products</h3>
    <p class="extracted-style-18"><%= productCount %></p>
    <a href="/admin/products" class="btn btn-sm btn-secondary">Manage Products</a>
  </div>

  <!-- Categories Stat -->
  <div class="admin-card extracted-style-15">
    <div class="extracted-style-16"><i class="fas fa-tags"></i></div>
    <h3 class="extracted-style-17">Total Categories</h3>
    <p class="extracted-style-19"><%= categoryCount %></p>
    <a href="/admin/categories" class="btn btn-sm btn-secondary">Manage Categories</a>
  </div>

  <!-- Orders Stat -->
  <div class="admin-card extracted-style-15">
    <div class="extracted-style-16"><i class="fas fa-shopping-cart"></i></div>
    <h3 class="extracted-style-17">Total Orders</h3>
    <p class="extracted-style-20"><%= orderCount %></p>
    <a href="/admin/orders" class="btn btn-sm btn-secondary">Manage Orders</a>
  </div>

  <!-- Users Stat -->
  <div class="admin-card extracted-style-15">
    <div class="extracted-style-16"><i class="fas fa-users"></i></div>
    <h3 class="extracted-style-17">Total Users</h3>
    <p class="extracted-style-21"><%= userCount %></p>
  </div>
</div>
