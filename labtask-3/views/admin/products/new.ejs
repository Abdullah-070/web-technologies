<div class="admin-card extracted-style-31">
  <form action="/admin/products" method="POST" enctype="multipart/form-data">
    <div class="extracted-style-32">
      <div class="extracted-style-2">
        <label for="name" class="extracted-style-3">Product Name</label>
        <input type="text" id="name" name="name" required class="extracted-style-4">
      </div>
      <div class="extracted-style-2">
        <label for="price" class="extracted-style-3">Price ($)</label>
        <input type="number" id="price" name="price" step="0.01" min="0" required class="extracted-style-4">
      </div>
    </div>

    <div class="extracted-style-2">
      <label for="category" class="extracted-style-3">Category</label>
      <select id="category" name="category" required class="extracted-style-4">
        <option value="" disabled selected>Select a category</option>
        <% categories.forEach(cat => { %>
          <option value="<%= cat._id %>"><%= cat.name %></option>
        <% }) %>
      </select>
    </div>

    <div class="extracted-style-2">
      <label for="image" class="extracted-style-3">Product Image</label>
      <input type="file" id="image" name="image" accept="image/*" class="extracted-style-34">
      <small class="extracted-style-36">Or provide an external URL (optional if file is selected)</small>
      <input type="text" name="image_url" placeholder="https://..." class="extracted-style-37">
    </div>

    <div class="extracted-style-5">
      <label for="description" class="extracted-style-3">Description</label>
      <textarea id="description" name="description" rows="5" class="extracted-style-4"></textarea>
    </div>

    <div class="extracted-style-6">
      <button type="submit" class="btn btn-primary">Create Product</button>
      <a href="/admin/products" class="btn btn-secondary">Cancel</a>
    </div>
  </form>
</div>
