<div class="admin-card extracted-style-31">
  <form action="/admin/products/edit/<%= product._id %>" method="POST" enctype="multipart/form-data">
    <div class="extracted-style-32">
      <div class="extracted-style-2">
        <label for="name" class="extracted-style-3">Product Name</label>
        <input type="text" id="name" name="name" value="<%= product.name %>" required class="extracted-style-4">
      </div>
      <div class="extracted-style-2">
        <label for="price" class="extracted-style-3">Price ($)</label>
        <input type="number" id="price" name="price" step="0.01" min="0" value="<%= product.price %>" required class="extracted-style-4">
      </div>
    </div>

    <div class="extracted-style-2">
      <label for="category" class="extracted-style-3">Category</label>
      <select id="category" name="category" required class="extracted-style-4">
        <% categories.forEach(cat => { %>
          <option value="<%= cat._id %>" <%= product.category && product.category.toString() === cat._id.toString() ? 'selected' : '' %>><%= cat.name %></option>
        <% }) %>
      </select>
    </div>

    <div class="extracted-style-2">
      <label class="extracted-style-3">Current Image</label>
      <div class="extracted-style-2">
        <img src="<%= product.image %>" alt="Current Image" class="extracted-style-33">
      </div>
      <label for="image" class="extracted-style-3">Replace Product Image</label>
      <input type="file" id="image" name="image" accept="image/*" class="extracted-style-34">
    </div>

    <div class="extracted-style-5">
      <label for="description" class="extracted-style-3">Description</label>
      <textarea id="description" name="description" rows="5" class="extracted-style-4"><%= product.description %></textarea>
    </div>

    <div class="extracted-style-6">
      <button type="submit" class="btn btn-primary">Update Product</button>
      <a href="/admin/products" class="btn btn-secondary">Cancel</a>
    </div>
  </form>
</div>
