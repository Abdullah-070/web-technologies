<div class="admin-card">
  <div class="extracted-style-5">
    <h3 class="extracted-style-8">Customer Orders</h3>
  </div>

  <table class="admin-table">
    <thead>
      <tr>
        <th>Order ID</th>
        <th>Customer</th>
        <th>Total</th>
        <th>Status</th>
        <th>Date</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (orders && orders.length > 0) { %>
        <% orders.forEach(order => { %>
          <tr>
            <td><code>#<%= order._id.toString().substring(0, 8) %>...</code></td>
            <td><%= order.user.name %></td>
            <td>$<%= order.total.toFixed(2) %></td>
            <td>
              <span class="badge extracted-style-30">
                <%= order.status %>
              </span>
            </td>
            <td><%= order.createdAt.toLocaleDateString() %></td>
            <td>
              <a href="/admin/orders/<%= order._id %>" class="btn btn-sm btn-secondary" title="View Details">
                <i class="fas fa-eye"></i> Details
              </a>
            </td>
          </tr>
        <% }) %>
      <% } else { %>
        <tr>
          <td colspan="6" class="extracted-style-12">No orders found.</td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>
