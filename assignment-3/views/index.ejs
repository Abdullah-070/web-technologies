<div class="hero">
  <div class="hero-content">
    <h1><%= title %></h1>
    <p><%= description %></p>
    <a href="/shop" class="btn btn-primary">Start Shopping</a>
  </div>
</div>

<section class="featured-section container" id="featured">
  <h2 class="featured-title">Featured Products</h2>

  <div class="product-grid">
    <div class="product-card">
      <img src="/Assets/Air filter.png" alt="Air Filter" class="product-image">
      <div class="product-info">
        <span class="product-category">Filters</span>
        <h3 class="product-title">Air Filter</h3>
        <p class="product-desc">Premium quality air filter for engine protection</p>
        <div class="product-bottom">
          <span class="product-price">$25.99</span>
          <a href="/shop" class="btn btn-secondary">Add to Cart</a>
        </div>
      </div>
    </div>
    
    <div class="product-card">
      <img src="/Assets/Engine Oil.png" alt="Engine Oil" class="product-image">
      <div class="product-info">
        <span class="product-category">Oil & Additives</span>
        <h3 class="product-title">Engine Oil</h3>
        <p class="product-desc">High-performance synthetic engine oil</p>
        <div class="product-bottom">
          <span class="product-price">$15.99</span>
          <a href="/shop" class="btn btn-secondary">Add to Cart</a>
        </div>
      </div>
    </div>

    <div class="product-card">
      <img src="/Assets/Head light.png" alt="Head Light" class="product-image">
      <div class="product-info">
        <span class="product-category">Lights</span>
        <h3 class="product-title">Head Light</h3>
        <p class="product-desc">Bright LED headlight for improved visibility</p>
        <div class="product-bottom">
          <span class="product-price">$25.99</span>
          <a href="/shop" class="btn btn-secondary">Add to Cart</a>
        </div>
      </div>
    </div>

    <div class="product-card">
      <img src="/Assets/Rear light.png" alt="Rear Light" class="product-image">
      <div class="product-info">
        <span class="product-category">Lights</span>
        <h3 class="product-title">Rear Light</h3>
        <p class="product-desc">Safety-focused rear light assembly</p>
        <div class="product-bottom">
          <span class="product-price">$20.99</span>
          <a href="/shop" class="btn btn-secondary">Add to Cart</a>
        </div>
      </div>
    </div>
  </div>
</section>
