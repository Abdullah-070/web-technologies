<div class="container page-header">
  <h2>Your Cart</h2>
</div>

<div class="container cart-container">
  <% if (cartItems.length > 0) { %>
    <table class="cart-table">
      <thead>
        <tr class="cart-header-row">
          <th class="cart-header-cell">Product</th>
          <th class="cart-header-cell">Price</th>
          <th class="cart-header-cell">Quantity</th>
          <th class="cart-header-cell">Total</th>
          <th class="cart-header-cell">Action</th>
        </tr>
      </thead>
      <tbody>
        <% cartItems.forEach(item => { %>
          <tr class="cart-row">
            <td class="cart-cell cart-product-cell">
              <img src="<%= item.product.image %>" alt="<%= item.product.name %>" class="cart-product-img">
              <span><%= item.product.name %></span>
            </td>
            <td class="cart-cell">$<%= item.product.price.toFixed(2) %></td>
            <td class="cart-cell"><%= item.quantity %></td>
            <td class="cart-cell">$<%= (item.product.price * item.quantity).toFixed(2) %></td>
            <td class="cart-cell">
              <form action="/cart/remove/<%= item.product._id %>" method="POST" class="remove-form">
                <button type="submit" class="btn-remove">Remove</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    
    <div class="cart-footer">
      <h3>Total: $<%= total.toFixed(2) %></h3>
      <a href="/shop" class="btn btn-primary btn-continue">Continue Shopping</a>
    </div>
  <% } else { %>
    <div class="empty-state">
      <h3>Your cart is empty</h3>
      <p>Go back to the <a href="/shop">shop</a> to add some products.</p>
    </div>
  <% } %>
</div>
