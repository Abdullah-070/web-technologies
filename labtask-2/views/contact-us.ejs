<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Us - Auto Care</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <!-- TOP HEADER -->
    <header class="top-header">
        <div class="container">
            <div class="header-content">
                <div class="logo-section">
                    <img src="/Assets/logo.png" alt="Auto Care" class="logo">
                    <h2>Auto Care</h2>
                </div>
                <div class="header-buttons">
                    <button class="btn btn-outline-primary">Become a Partner</button>
                    <button class="btn btn-outline-dark">Login</button>
                    <button class="btn btn-danger">Sign Up</button>
                </div>
            </div>
        </div>

    <!-- NAVIGATION BAR -->
    <nav class="navbar">
        <div class="container">
            <button class="hamburger-btn" id="hamburgerBtn" aria-label="Toggle menu">
                <span class="hamburger-line"></span>
                <span class="hamburger-line"></span>
                <span class="hamburger-line"></span>
            </button>
            
            <div class="navbar-content" id="navbarContent">
                <ul class="navbar-nav">
                    <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="/#about">About</a></li>
                    <li class="nav-item"><a class="nav-link" href="/contact-us">Contact</a></li>
                    <li class="nav-item dropdown-menu-container">
                        <a class="nav-link" href="/#products">Products</a>
                        <div class="dropdown-menu-custom">
                            <a href="#products-category-1">Engine Parts</a>
                            <a href="#products-category-2">Brake Systems</a>
                            <a href="#products-category-3">Lighting</a>
                            <a href="#products-category-4">Batteries</a>
                            <a href="#products-category-5">Filters</a>
                        </div>
                    </li>
                </ul>
                <div class="search-section">
                    <input type="text" class="search-box" placeholder="Search with SKU or Keyword...">
                </div>
            </div>
        </div>
    </nav>
    </header>

    <!-- CONTACT SECTION -->
    <section class="contact-section" style="padding: 60px 0; text-align: center;">
        <div class="container">
            <h1 style="margin-bottom: 20px; font-size: 2.5rem;">Contact Us</h1>
            <p style="margin-bottom: 40px; font-size: 1.1rem; color: #666;">
                Have questions? We'd love to hear from you. Get in touch with our team.
            </p>
            
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px; margin-bottom: 50px;">
                <div style="padding: 30px;">
                    <h3 style="font-size: 1.3rem; margin-bottom: 10px;">📞 Phone</h3>
                    <p style="color: #666;">1-800-AUTO-CARE</p>
                </div>
                <div style="padding: 30px;">
                    <h3 style="font-size: 1.3rem; margin-bottom: 10px;">📧 Email</h3>
                    <p style="color: #666;">support@autocare.com</p>
                </div>
                <div style="padding: 30px;">
                    <h3 style="font-size: 1.3rem; margin-bottom: 10px;">📍 Address</h3>
                    <p style="color: #666;">123 Auto Parts Ave, Service City, SC 12345</p>
                </div>
            </div>

            <!-- Contact Form -->
            <div style="max-width: 600px; margin: 0 auto; background: #f9f9f9; padding: 40px; border-radius: 8px;">
                <h3 style="margin-bottom: 20px; font-size: 1.5rem;">Send us a Message</h3>
                <form>
                    <div style="margin-bottom: 20px;">
                        <input type="text" placeholder="Your Name" style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 4px; font-size: 1rem;">
                    </div>
                    <div style="margin-bottom: 20px;">
                        <input type="email" placeholder="Your Email" style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 4px; font-size: 1rem;">
                    </div>
                    <div style="margin-bottom: 20px;">
                        <input type="text" placeholder="Subject" style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 4px; font-size: 1rem;">
                    </div>
                    <div style="margin-bottom: 20px;">
                        <textarea placeholder="Your Message" rows="6" style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 4px; font-size: 1rem; font-family: Arial, sans-serif;"></textarea>
                    </div>
                    <button type="submit" class="btn" style="background: #007bff; color: white; padding: 12px 30px; border: none; border-radius: 4px; cursor: pointer; font-size: 1rem;">Send Message</button>
                </form>
            </div>
        </div>
    </section>

    <!-- FOOTER -->
    <footer class="footer-section" style="background: #333; color: #fff; padding: 40px 0; margin-top: 60px;">
        <div class="container">
            <div style="text-align: center;">
                <p>&copy; 2026 AUTO CARE CO. ALL RIGHTS RESERVED.</p>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="/js/script.js"></script>
</body>
</html>
