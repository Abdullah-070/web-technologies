<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Auto Care' %></title>
  <link rel="stylesheet" href="/css/style.css">
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
</head>
<body>
  <nav class="navbar">
    <div class="container nav-container">
      <a href="/" class="logo">
        <img src="/Assets/logo.png" alt="Auto Care">
        <span>Auto Care</span>
      </a>
      <button class="hamburger" id="hamburger-menu">&#9776;</button>
      <div class="nav-menu" id="nav-menu">
        <ul class="nav-links">
          <li><a href="/">Home</a></li>
          <li><a href="/shop">Shop</a></li>
          <li class="dropdown">
            <a href="#">Categories &#x25BC;</a>
            <ul class="dropdown-menu">
              <% if (categories && categories.length > 0) { %>
                <% categories.forEach(cat => { %>
                  <li><a href="/shop/category/<%= cat.slug %>"><%= cat.name %></a></li>
                <% }) %>
              <% } else { %>
                <li class="no-categories">No categories</li>
              <% } %>
            </ul>
          </li>
        </ul>
        <ul class="nav-links right-links">
          <li><a href="/cart">Cart (<%= typeof cartCount !== 'undefined' ? cartCount : 0 %>)</a></li>
          <% if (user) { %>
            <% if (user.role === 'admin') { %>
              <li><a href="/admin">Admin Panel</a></li>
            <% } %>
            <li><a href="/auth/logout">Logout (<%= user.name %>)</a></li>
          <% } else { %>
            <li><a href="/auth/login">Login</a></li>
            <li><a href="/auth/register">Register</a></li>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container">
    <% if (success_msg && success_msg.length > 0) { %>
      <% success_msg.forEach(msg => { %>
        <div class="flash-success">
          <%= msg %>
        </div>
      <% }) %>
    <% } %>
    <% if (error_msg && error_msg.length > 0) { %>
      <% error_msg.forEach(msg => { %>
        <div class="flash-error">
          <%= msg %>
        </div>
      <% }) %>
    <% } %>
  </div>

  <main class="main-content">
    <%- body %>
  </main>

  <footer class="footer">
    <div class="container">
      <p>&copy; 2026 Auto Care. All rights reserved.</p>
    </div>
  </footer>

  <script src="/js/main.js"></script>
</body>
</html>
